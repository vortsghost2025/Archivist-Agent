{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "kilo/kilo-auto/free",
  "instructions": [
    "ENFORCED: Before performing any action in this project, read S:/.global/BOOTSTRAP.md",
    "ENFORCED: Follow the governance constraints from CHECKPOINTS.md - all 7 checkpoints must pass before major actions",
    "ENFORCED: Maintain agent/user separation - use 'you' for user, 'I' for agent, avoid 'we' for decisions",
    "ENFORCED: If governance is unclear or user request conflicts with governance, ask for clarification before proceeding",
    "MANUAL: Use /governance command to reload governance constraints at any time",
    "MANUAL: Use /checkpoints command to run full checkpoint verification",
    "MANUAL: Use /drift-check to assess current conversation for drift signals"
  ],
  "agent": {
    "orchestrator": {
      "model": "kilo/kilo-auto/free"
    },
    "plan": {
      "model": "nvidia/openai/gpt-oss-120b"
    },
    "code": {
      "model": "nvidia/z-ai/glm-5.1"
    },
    "build": {
      "model": "kilo/kilo-auto/free"
    },
    "debug": {
      "model": "nvidia/openai/gpt-oss-120b"
    },
    "ask": {
      "model": "kilo/kilo-auto/free"
    },
    "general": {
      "model": "kilo/kilo-auto/free"
    },
    "code-reviewer": {
      "model": "nvidia/openai/gpt-oss-120b"
    }
  },
  "permission": {
    "external_directory": {
      "S:/Archivist-Agent": "allow",
      "S:/.global": "allow",
      "S:/SwarmMind": "allow"
    },
    "bash": {
      "git": "allow",
      "cargo": "allow",
      "npm": "allow",
      "node": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "S:/Archivist-Agent": "allow",
      "S:/.global": "allow"
    }
  },
  "command": {
    "/governance": {
      "template": "Read S:/.global/BOOTSTRAP.md and summarize the governance constraints that apply to this session. List: 1) Your role as governance partner, 2) The single entry point rule, 3) What constitutes drift, 4) The checkpoints you must apply before major actions.",
      "description": "Load governance constraints from BOOTSTRAP.md"
    },
    "/checkpoints": {
      "template": "Read S:/.global/CHECKPOINTS.md and run through all 7 checkpoints for the current session. Report your UDS score and each checkpoint result.",
      "description": "Run checkpoint verification"
    },
    "/drift-check": {
      "template": "Assess the current conversation for drift signals. Check for: agreement without verification, identity fusion, confidence mirroring, narrative inflation, correction smoothing. Report your UDS score.",
      "description": "Check for drift in current conversation"
    },
    "/code-review": {
      "template": "Read S:/.global/BOOTSTRAP.md first. Then perform a read‑only code review of the Tauri application. Do NOT make changes. Focus on: security, code quality, performance, maintainability. Report findings in a structured format.",
      "description": "Governance-aware code review"
    },
    "/verify": {
      "template": "Run SwarmMind verification on the last execution result. Categorize claims as VERIFIED, MEASURED, or UNTESTED. Report any hardcoded values or fake confidence detected.",
      "description": "Run truth verification on execution results"
    }
  }
}
