{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "kilo/kilo-auto/free",
  "agent": {
    "orchestrator": {
      "model": "kilo/kilo-auto/free"
    },
    "plan": {
      "model": "nvidia/openai/gpt-oss-120b"
    },
    "code": {
      "model": "nvidia/z-ai/glm-5.1"
    },
    "build": {
      "model": "kilo/kilo-auto/free"
    },
    "debug": {
      "model": "nvidia/openai/gpt-oss-120b"
    },
    "ask": {
      "model": "kilo/kilo-auto/free"
    },
    "general": {
      "model": "kilo/kilo-auto/free"
    },
    "code-reviewer": {
      "model": "nvidia/openai/gpt-oss-120b"
    }
  },
  "provider": {
    "nvidia": {
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": {
      "S:\\\\self-organizing-library": "allow",
      "S:\\\\Archivist-Agent": "allow",
      "S:\\\\SwarmMind Self-Optimizing Multi-Agent AI System": "allow",
      "*": "allow"
    },
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "web": {
      "*": "allow"
    }
  }
}
