{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "anthropic/claude-3-sonnet-20240229",
  "skills": [
    "archivist-governance",
    "systematic-debugging",
    "test-driven-development",
    "requesting-code-review",
    "receiving-code-review",
    "verification-before-completion"
  ],
  "mcp": {
    "servers": ["github", "supabase", "playwright", "context7", "serena"]
  },
  "governance": {
    "entry_point": "S:/.global/BOOTSTRAP.md",
    "user_drift_scoring": "S:/.global/USER_DRIFT_SCORING.md",
    "checkpoints": "S:/.global/CHECKPOINTS.md",
    "log_file": "S:/.global/cps_log.jsonl"
  },
  "permission": {
    "external_directory": {
      "S:/Archivist-Agent": "allow",
      "S:/.global": "allow"
    },
    "bash": {
      "git": "allow",
      "cargo": "allow",
      "npm": "allow",
      "python": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "S:/Archivist-Agent": "allow",
      "S:/.global": "allow"
    }
  },
  "hooks": {
    "pre_session": "Read S:/.global/BOOTSTRAP.md",
    "pre_action": "Evaluate UDS checkpoint 0",
    "post_action": "Log to cps_log.jsonl"
  }
}
