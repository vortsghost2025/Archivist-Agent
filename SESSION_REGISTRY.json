  "rules": {
    "session_start": [
      "Read SESSION_REGISTRY.json",
      "Read .session-mode file if present",
      "If .session-mode exists, use declared mode",
      "Otherwise default to mode: governing",
      "Check for active sessions on target lanes",
      "If mode == governing: Acquire lock file in own lane",
      "Register session in registry with mode",
      "If mode == governing: Begin heartbeat (60s interval)"
    ],
    "session_end": [
      "Remove session from registry",
      "If mode == governing: Release lock file",
      "If mode == governing: Write session handoff document",
      "If mode == observer: No handoff required"
    ],
    "file_modification": [
      "Check SESSION_REGISTRY.json for concurrent sessions",
      "If other session active on same lane, queue notification",
      "If mode == observer: READ ONLY - reject write attempts",
      "If mode == governing: Acquire file lock before write",
      "Write modification log to SESSION_NOTIFICATIONS"
    ],
    "conflict_handling": [
      "If two sessions modify same file, last-writer-wins",
      "Loser session receives notification of conflict",
      "Manual resolution required for critical files",
      "Observer sessions cannot cause conflicts (read-only)"
    ],
    "heartbeat_timeout": [
      "If last_heartbeat > lock_timeout_ms:",
      " IF mode == governing:",
      " Mark session terminated",
      " Clear stale lock file",
      " Update SESSION_REGISTRY.json",
      " Create session handoff document if work incomplete",
      " ELIF mode == observer:",
      " Mark session inactive (not terminated)",
      " No handoff document",
      " Schedule cleanup after 24h idle"
    ],
    "observer_timeout": [
      "Observer sessions do not require heartbeat",
      "After 24h idle, move to inactive_sessions",
      "Inactive sessions auto-cleanup after 7 days",
      "Manual cleanup: Remove from inactive_sessions"
    ]
  },
  "mode_definitions": {
    "governing": {
      "description": "Primary agent with write access and heartbeat requirement",
      "heartbeat_required": true,
      "can_write": true,
      "timeout_behavior": "terminate",
      "use_case": "Production agent lanes"
    },
    "observer": {
      "description": "Read-only test session, no heartbeat enforcement",
      "heartbeat_required": false,
      "can_write": false,
      "timeout_behavior": "inactive",
      "use_case": "Stress testing, parallel verification"
    },
    "ephemeral": {
      "description": "Short-lived session, auto-expires after 5 min idle",
      "heartbeat_required": false,
      "can_write": false,
      "timeout_behavior": "auto_remove",
      "use_case": "Quick queries, one-shot tasks"
    },
    "shadow": {
      "description": "Mirrors primary session, never terminates independently",
      "heartbeat_required": false,
      "can_write": false,
      "timeout_behavior": "follow_primary",
      "use_case": "Parallel read-only observers"
    }
  }
