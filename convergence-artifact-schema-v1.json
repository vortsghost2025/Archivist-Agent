{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Convergence Artifact Schema v1",
  "description": "Required fields for convergence artifacts to prevent contradictions",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "lane",
    "generated_at",
    "status",
    "p0_findings",
    "p1_findings",
    "p2_findings",
    "active_blockers",
    "contradicts",
    "evidence"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["e2e-summary", "blocker-resolution", "escalation-response", "contradiction-report", "convergence-status", "identity-audit"]
    },
    "lane": {
      "type": "string",
      "enum": ["archivist", "kernel", "library", "swarmmind"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "PASS-WARN", "RESOLVED", "FAILED", "BLOCKED"]
    },
    "p0_findings": {
      "type": "integer",
      "minimum": 0
    },
    "p1_findings": {
      "type": "integer",
      "minimum": 0
    },
    "p2_findings": {
      "type": "integer",
      "minimum": 0
    },
    "active_blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "contradicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact", "field", "expected", "actual"],
        "properties": {
          "artifact": {"type": "string"},
          "field": {"type": "string"},
          "expected": {"type": "string"},
          "actual": {"type": "string"}
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "hash"],
      "properties": {
        "file": {"type": "string"},
        "line": {"type": "integer", "minimum": 1},
        "hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "findings_count": {
      "type": "integer",
      "minimum": 0
    },
    "scanned_artifacts": {
      "type": "integer",
      "minimum": 0
    },
    "stale_threshold_hours": {
      "type": "number",
      "minimum": 0
    },
    "severity_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["P0", "P1", "P2"],
      "properties": {
        "P0": { "type": "integer", "minimum": 0 },
        "P1": { "type": "integer", "minimum": 0 },
        "P2": { "type": "integer", "minimum": 0 }
      }
    },
    "root": {
      "type": "string"
    }
  }
}
